# AI review settings. These are optional: after the app starts, you can also fill them in on the Settings page.
# The Settings page keeps the access key on this machine and never shows it again.
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-xxx
LLM_MODEL=deepseek-v4-flash
LLM_STRUCTURED_OUTPUT=auto

# App runtime
DB_PATH=backend/data/easycode.db
EASYCODE_PROBLEM_BANK_ROOT=
EASYCODE_PROBLEMS_JSON_PATH=backend/data/problems.json
PROBLEM_BANK_HOST_PATH=./examples/problem-bank
EXECUTOR=pyodide

# Local web dev
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175
VITE_API_BASE=http://127.0.0.1:8000/api
